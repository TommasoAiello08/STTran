# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.DS_Store

# Virtualenv / IDE
.venv/
.venv.bak/
.venv_ci/
.env
venv/
.idea/
.vscode/
.ipynb_checkpoints/

# Large local artifacts (datasets, weights, pickles)
*.pkl
*.pth
*.pt
*.ckpt
*.tar
*.so

# Build artifacts
**/build/
**/*.egg-info/

# Generated outputs / logs (copy finals to results/ for the report)
output/
output2_more/
plots/
pretrained/
ckpts/
study_pack_*/
**/*.log
**/*.log.bak

# Results artefacts — keep README + .gitkeep only
results/*
!results/README.md
!results/.gitkeep
!results/plots/
results/plots/*
!results/plots/.gitkeep
!results/tables/
results/tables/*
!results/tables/.gitkeep
!results/qualitative/
results/qualitative/*
!results/qualitative/.gitkeep

# Local VIDVRD repacks (very large)
vidvrd-dataset_480_s8_FIXED/
vidvrd-dataset_480_s8_fixed/
final_dataset_vidvrd*/

# Downloaded word vectors
data/glove.6B.*
data/*.zip
data/*.txt

# APT / STTran checkpoints and run artefacts
data/apt_pretrain/
data/apt_finetune/
data/apt_pretrain_*/
data/apt_finetune_*/
fasterRCNN/models/*.pth

# Keep only Action Genome dataset folder skeleton in-repo
dataset/**
!dataset/
!dataset/ag/
!dataset/ag/annotations/
!dataset/ag/frames/
!dataset/ag/videos/
!dataset/ag/.gitignore

# Generated figures (scripts write under output/ or results/)
*.png
*.jpg
*.jpeg
*.gif
*.pdf
*.svg

# Local notebook copies
* (copy).ipynb
* (*).ipynb
